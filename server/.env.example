# Anthropic (Claude) API キー: https://console.anthropic.com
# （写真からの食材認識でのみ使用。レシピは楽天レシピAPIから日本語で取得するため翻訳は不要）
ANTHROPIC_API_KEY=

# 楽天レシピAPI・楽天市場API（新仕様）: https://webservice.rakuten.co.jp/
# アプリ管理画面の applicationId(UUID) と accessKey(pk_...) の両方が必要。
# 楽天市場API（食品ロス特設ページの商品検索。server/rakutenIchiba.js）も同じ値を流用する。
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
# アプリに登録した「許可Webサイト/IP」に一致する Referer（例: example.com を登録したら http://example.com/）
RAKUTEN_REFERER=http://example.com/

# 任意: 楽天アフィリエイトID。設定すると楽天市場APIのレスポンスにaffiliateUrl（アフィリエイト計測付きURL）が
# 含まれるようになり、食品ロス特設ページの商品詳細モーダルの「楽天市場で詳しく見る」がそちらを使うようになる。
# 未設定でも商品検索自体は動作する（その場合は通常のitemUrlを使用）。
# 取得方法: https://affiliate.rakuten.co.jp/ でアフィリエイト登録後、発行されるIDを設定する。
RAKUTEN_AFFILIATE_ID=

# 任意: API サーバーのポート（未指定なら 8787。vite.config.ts のプロキシ先と一致させること）
# API_PORT=8787
