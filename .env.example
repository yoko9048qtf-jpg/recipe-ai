# これはルート用の env テンプレートです。
# Vercel CLI (`vercel dev`) はプロジェクトルートの .env を読み込みます。
# ローカルの `npm run dev`（Express を直接起動）では代わりに server/.env.example を使ってください。
#
# Vercel にデプロイする場合は、このファイルをコピーせず、
# Vercel プロジェクトの Settings → Environment Variables に同じ変数を設定してください。

# Anthropic (Claude) API キー: https://console.anthropic.com
# （写真からの食材認識・レシピ手順の生成に使用）
ANTHROPIC_API_KEY=

# 楽天レシピAPI（新仕様）: https://webservice.rakuten.co.jp/
# アプリ管理画面の applicationId(UUID) と accessKey(pk_...) の両方が必要。
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
# アプリに登録した「許可Webサイト/IP」に一致する Referer（例: example.com を登録したら http://example.com/）
RAKUTEN_REFERER=http://example.com/
